{
  "name": "gonyik-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "setup": "node -e \"import('tsx').then(() => import('./server/db.ts')).then(m => m.initDatabase())\""
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.1.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "framer-motion": "^11.18.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "multer": "^1.4.5-lts.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^7.14.2",
    "sharp": "^0.33.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}
